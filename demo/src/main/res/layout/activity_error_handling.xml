<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Valid URL with listener:"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvValidStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />

        <ImageView
            android:id="@+id/ivValid"
            android:layout_width="200dp"
            android:layout_height="200dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="Invalid URL (shows error image):"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvErrorStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />

        <ImageView
            android:id="@+id/ivError"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="#CCCCCC" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="Null data (shows fallback):"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivFallback"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:background="#CCCCCC" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:text="Circle with border + error handling:"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivCircleError"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</ScrollView>
